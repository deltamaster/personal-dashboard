# Copy to terraform.tfvars (gitignored). Do not commit.

region     = "cn-shanghai"
access_key = "LTAI..."          # RAM user AK (calls AssumeRole)
secret_key = "..."              # RAM user secret
role_arn   = "acs:ram::1234567890123456:role/your-provision-role"

# From ACR console → instance → login server
acr_registry = "crpi-xxxxx.cn-shanghai.personal.cr.aliyuncs.com"

# Optional: attach existing runtime role to FC (OTS/OSS). Leave empty to skip.
# fc_execution_role_arn = "acs:ram::1234567890123456:role/your-runtime-role"

# FC runtime secrets (same values as .env.local / production)
auth_secret                      = "generate-with-openssl-rand-base64-32"
auth_microsoft_entra_id_id       = "e96b9971-..."
auth_microsoft_entra_id_secret   = "..."
runtime_access_key               = "LTAI..."   # can match access_key if same principal
runtime_secret_key               = "..."

# Set false if huhansen.cn is already registered on CDN (import instead)
# create_cdn_domain = true

# Push a placeholder image to ACR before first apply if FC create fails:
# initial_fc_image = "crpi-xxxxx.cn-shanghai.personal.cr.aliyuncs.com/personal-dashboard/api:latest"
