# Copy to .env.local for local development
AUTH_URL=http://localhost:3000
AUTH_SECRET=generate-with-openssl-rand-base64-32

AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
ALLOWED_USER_EMAIL=huhansen318@hotmail.com

ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIBABA_CLOUD_ROLE_ARN=[REDACTED]
ALIBABA_CLOUD_ROLE_SESSION_NAME=personal-dashboard
ALIBABA_CLOUD_REGION=cn-shanghai
OTS_ENDPOINT=https://pd-dashboard.cn-shanghai.ots.aliyuncs.com
OTS_INSTANCE_NAME=pd-dashboard

# --- QA / agent environment ---
# Disable Microsoft auth so the app runs without OAuth (set BOTH; the NEXT_PUBLIC
# one is baked into the client bundle). Leave empty/true to enforce auth.
MICROSOFT_AUTH_ENABLED=
NEXT_PUBLIC_MICROSOFT_AUTH_ENABLED=
# Set to 1 to serve dummy data for ALL modules (movies/portfolio/travel) without OTS.
QA_DUMMY_DATA=

# Set to 1 to use sample travel data instead of OTS (dev only; default is real OTS when configured)
TRAVEL_DUMMY_DATA=

# Set to 1 to use sample portfolio data instead of OTS (dev only; default is real OTS when configured)
PORTFOLIO_DUMMY_DATA=

# Set to 1 to use sample movies data instead of OTS (dev only)
MOVIES_DUMMY_DATA=

OSS_WEB_BUCKET=huhansen-web
OSS_WEB_REGION=oss-cn-shanghai
OSS_VAULT_BUCKET=personal-dashboard-vault
OSS_VAULT_REGION=oss-cn-shanghai
OSS_VAULT_ENDPOINT=oss-cn-shanghai.aliyuncs.com

# Photos are uploaded server-side (by the API) to a public, CDN-served bucket.
# OSS_MEDIA_BUCKET selects that bucket (falls back to OSS_WEB_BUCKET, then vault).
# Prod: the web bucket (huhansen-web); QA: the CDN-fronted bucket (pd-web-qa).
OSS_MEDIA_BUCKET=

# Public base URL stored in photo records / used to serve them. Falls back to
# AUTH_URL when unset. Prod CN: https://pd.huhansen.cn; QA: https://pd-qa.huhansen.com
MEDIA_PUBLIC_BASE_URL=

# --- SG QA stack (ap-southeast-1, pd-qa.huhansen.com) — uncomment to point local dev at QA ---
# ALIBABA_CLOUD_REGION=ap-southeast-1
# OTS_ENDPOINT=https://pd-dash-qa.ap-southeast-1.ots.aliyuncs.com
