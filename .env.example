# Copy to .env.local for local development
AUTH_URL=http://localhost:3000
AUTH_SECRET=generate-with-openssl-rand-base64-32

AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
ALLOWED_USER_EMAIL=huhansen318@hotmail.com

ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIBABA_CLOUD_ROLE_ARN=acs:ram::1197388755513152:role/resourceadmin
ALIBABA_CLOUD_ROLE_SESSION_NAME=personal-dashboard
ALIBABA_CLOUD_REGION=ap-southeast-1
OTS_ENDPOINT=https://pd-dash-sg.ap-southeast-1.ots.aliyuncs.com
OTS_INSTANCE_NAME=pd-dash-sg

# --- QA / agent environment ---
# Disable Microsoft auth so the app runs without OAuth (set BOTH; the NEXT_PUBLIC
# one is baked into the client bundle). Leave empty/true to enforce auth.
MICROSOFT_AUTH_ENABLED=
NEXT_PUBLIC_MICROSOFT_AUTH_ENABLED=
# Set to 1 to serve dummy data for ALL modules (movies/portfolio/travel) without OTS.
QA_DUMMY_DATA=

# Set to 1 to use sample travel data instead of OTS (dev only; default is real OTS when configured)
TRAVEL_DUMMY_DATA=

# Set to 1 to use sample portfolio data instead of OTS (dev only; default is real OTS when configured)
PORTFOLIO_DUMMY_DATA=

# Set to 1 to use sample movies data instead of OTS (dev only)
MOVIES_DUMMY_DATA=

OSS_WEB_BUCKET=pd-web-sg
OSS_WEB_REGION=oss-ap-southeast-1
OSS_VAULT_BUCKET=pd-vault-sg
OSS_VAULT_REGION=oss-ap-southeast-1
OSS_VAULT_ENDPOINT=oss-ap-southeast-1.aliyuncs.com
